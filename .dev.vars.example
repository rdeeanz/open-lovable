# Copy to .dev.vars for: pnpm preview / pnpm deploy
# Cloudflare Workers local secrets (never commit .dev.vars)

FIRECRAWL_API_KEY=
AUTH_SECRET=
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Admin
MEMBER_EMAIL=member@example.com
MEMBER_PASSWORD=password123
MEMBER_NAME=Member

# AI (at least one)
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# Sandbox (Vercel recommended - runs externally, not on Cloudflare)
SANDBOX_PROVIDER=vercel
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
